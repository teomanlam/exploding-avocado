---
import '../styles/global.css';
const site = {
  title: 'Teoman Lam | Dataflows & Technical Delivery',
  description: 'Technical delivery lead specializing in dataflows, data structure, and process scaling across the DACH region. Seeking business analyst and data analyst roles.',
  url: 'https://teolam.com',
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; script-src 'self'; img-src 'self' data:; connect-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none';" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Teoman Lam" />
    <meta name="keywords" content="Teoman Lam, dataflows, data structure, technical leadership, process scaling, integration, DACH, Switzerland, business analyst, data analyst, technical product owner, project manager, data analytics specialist" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content="Teoman Lam" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={site.title} />
    <meta name="twitter:description" content={site.description} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Teoman Lam",
      "url": "https://teolam.com",
      "jobTitle": "IT Project Manager",
      "description": site.description,
      "sameAs": [
        "https://www.linkedin.com/in/teomanlam"
      ],
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "ZHAW Zurich University of Applied Sciences",
        "url": "https://www.zhaw.ch"
      },
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "name": "Project Management Professional (PMP)",
        "credentialCategory": "Certification",
        "recognizedBy": {
          "@type": "Organization",
          "name": "Project Management Institute (PMI)",
          "url": "https://www.pmi.org"
        }
      }
    })} />
  </head>
  <body>
    <div class="page">
      <nav>
        <div class="brand">Teoman Lam</div>
        <div class="links">
          <a href="#education">Education</a>
          <a href="#experience">Experience</a>
          <a href="#skills">Skills</a>
          <a href="#certifications">Certifications</a>
          <a href="#others">Others</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>

      <div class="tag-row">
        <a class="tv-cat-pill" href="#skills">Technical Leadership</a>
        <a class="tv-cat-pill" href="#skills">Dataflows</a>
        <a class="tv-cat-pill" href="#skills">Data Structure</a>
        <a class="tv-cat-pill" href="#skills">Integration</a>
        <a class="tv-cat-pill" href="#skills">Scaling</a>
      </div>

      <section class="hero">
        <div class="badge">Technical Leadership · Dataflows · Data Structure</div>
        <h1>Leading technical teams to build and scale dataflows with strong data structure and integration discipline.</h1>
        <p class="tagline">I am Teo. For five years I have led technical projects across automotive, outdoor, retail logistics and fashion brands. I transitioned into business process optimization and built processes that scale internationally, mainly in the DACH region.

My core focus is automation and optimizing data structures and dataflows.</p>
        <a class="cta" href="#contact">Let's connect</a>
      </section>

      <section id="figures" class="figures-short">
        <div class="figure-card">
          <strong>30%</strong>
          <p>B2B revenue increase through fully automated order processes (EDI)</p>
        </div>
        <div class="figure-card">
          <strong>2'500+</strong>
          <p>Retail members (DACH) supported by an integrated B2B onboarding and automation solution</p>
        </div>
        <div class="figure-card">
          <strong>100%</strong>
          <p>Reduction in Swiss B2C returns support effort through complete automation</p>
        </div>
        <div class="figure-card">
          <strong>50–60%</strong>
          <p>Average overhead reduction in development teams through effective team leadership</p>
        </div>
      </section>

      <section id="education" class="section">
        <h2>Education</h2>
        <div class="cards">
          <div class="card">
            <strong>ZHAW Winterthur, School of Management and Law</strong>
            <p>September 2025 – Present · Bachelor of Science (BSc), Business Information Technology</p>
            <p>Current Grade: 5.25 / 6.0</p>
          </div>

          <div class="card">
            <strong>Informatikmittelschule IMS-T (Software Development), BWZ Rapperswil-Jona</strong>
            <p>August 2017 – July 2021 · Federal Vocational Baccalaureate (FVB) technical</p>
            <p>Grade: 5.0 / 6.0</p>
          </div>
        </div>
      </section>

      <section id="experience" class="section">
        <h2>Experience</h2>
        <div class="cards">
          <div class="card">
            <strong>Product Owner ERP & Logistics</strong>
            <p><em>BLACKROLL AG</em></p>
            <p>January 2025 – Present · Remote</p>
            <ul>
              <li>Led EDI procurement automation and B2B rollout for 2,500+ locations in Germany and Austria.</li>
              <li>Delivered 30% revenue growth through scalable integration and process improvements.</li>
              <li>Automated returns handling across all dimensions, eliminating manual customer care effort.</li>
              <li>Built integration documentation, release trains, and team processes to reduce handoff friction.</li>
            </ul>
          </div>

          <div class="card">
            <strong>IT Project Manager</strong>
            <p><em>FIREGROUP</em></p>
            <p>May 2022 – June 2024 · Hybrid</p>
            <ul>
              <li>Delivered digital relaunches and product configurators for automotive, outdoor, and furniture clients.</li>
              <li>Managed teams of 5 specialists and budgets up to six figures.</li>
              <li>Focused on customer-facing workflows, integration quality, and project profitability.</li>
            </ul>
          </div>

          <div class="card">
            <strong>Project Manager</strong>
            <p><em>Onebyte AG</em></p>
            <p>August 2021 – May 2022 · On-site</p>
            <ul>
              <li>Led end-to-end delivery for web projects with up to five-figure budgets.</li>
              <li>Delivered localized i18n solutions for a major Swiss gym chain.</li>
              <li>Coordinated developers across frontend, full stack, and backend workstreams.</li>
            </ul>
          </div>

          <div class="card">
            <strong>Junior Project Manager & Web Developer</strong>
            <p><em>Netmaster (Schweiz) AG</em></p>
            <p>August 2020 – July 2021 · On-site</p>
            <ul>
              <li>Supported web project operations, hosting stability, and client technical support.</li>
              <li>Maintained uptime and performance for multiple customer environments.</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="skills" class="section">
        <h2>Skills</h2>
        <div class="cards grid grid-2">
          <div class="card">
            <strong>Technical Leadership</strong>
            <ul>
              <li>Leading technical teams through delivery and integration</li>
              <li>Aligning stakeholders, engineers, and business goals</li>
              <li>Driving execution with clear technical ownership</li>
              <li>Building team processes for repeatable delivery</li>
            </ul>
          </div>
          <div class="card">
            <strong>Dataflows & Structure</strong>
            <ul>
              <li>Designing and scaling dataflows across systems</li>
              <li>Structuring data for consistency and integration</li>
              <li>Defining technical data process workflows</li>
              <li>Supporting data-driven operations with clean architecture</li>
            </ul>
          </div>
          <div class="card">
            <strong>Integration & Scaling</strong>
            <ul>
              <li>Systems integration across ERP, APIs, and middleware</li>
              <li>Process scaling and release train definition</li>
              <li>Operational handoff and documentation systems</li>
              <li>Quality and error reduction in technical workflows</li>
            </ul>
          </div>
          <div class="card">
            <strong>Process & Delivery</strong>
            <ul>
              <li>Scalable process definition</li>
              <li>Technical documentation and knowledge base design</li>
              <li>Standardization for repeatable delivery</li>
              <li>Customer-facing process optimization</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="certifications" class="section">
        <h2>Certifications</h2>
        <div class="cards">
          <div class="card">
            <strong>PMP — Project Management Professional (13 April 2026)</strong>
            <p>Certified in structured project leadership and large-scale delivery. <a class="pmi-link" href="https://www.pmi.org/" target="_blank" rel="noopener">PMI</a></p>
          </div>
        </div>
      </section>

      <section id="others" class="section">
        <h2>Focus & Interests</h2>
        <div class="cards grid grid-2">
          <div class="card">
            <strong>Career focus</strong>
            <ul>
              <li>AI and Data — Claude projects and agent prompting</li>
              <li>Dataflows, data structure, and integration scaling</li>
              <li>Technical delivery and systems integration</li>
              <li>Business analysis and data-technical collaboration</li>
            </ul>
          </div>
          <div class="card">
            <strong>Seeking roles</strong>
            <ul>
              <li>Business analyst</li>
              <li>Data analyst</li>
              <li>Technical product owner</li>
              <li>Project manager</li>
              <li>Data analytics specialist</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="freetime" class="section">
        <h2>Freetime</h2>
        <div class="card">
          <ul>
            <li>Fitness</li>
            <li>Brazilian Jiu Jitsu</li>
            <li>Coding</li>
          </ul>
        </div>
      </section>

      <section id="languages" class="section">
        <h2>Languages</h2>
        <div class="card">
          <ul>
            <li>German — Native</li>
            <li>Swiss German — Native</li>
            <li>English — Negotiation safe</li>
            <li>Türkçe — Conversational</li>
            <li>Korean — Basic</li>
          </ul>
        </div>
      </section>

      <section id="contact" class="section">
        <h2>Contact</h2>
        <div class="card">
          <strong>Happy to chat anytime.</strong>
          <p>I am available on LinkedIn and regularly active.</p>
          <a class="cta" href="https://www.linkedin.com/in/teomanlam?originalSubdomain=ch" target="_blank" rel="noopener">Visit LinkedIn ↗</a>
        </div>
      </section>

      <footer>
        <p>© {new Date().getFullYear()} Teoman Lam — teolam.com</p>
        <p class="footer-meta">
          <span class="version">v1.1.0</span>
          <span class="divider">·</span>
          <span class="made-in">Made in Switzerland <span class="swiss-flag" aria-label="Swiss flag" role="img"></span></span>
        </p>
      </footer>
    </div>
  </body>
</html>
